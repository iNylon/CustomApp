{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "OpenObserve Metrics / Prometheus API",
      "description": "Select the Prometheus-compatible datasource that exposes poc-metrics.",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Trend - CPU gebruik per runtime",
      "description": "Container-CPU uit cAdvisor, via de OpenTelemetry Collector naar poc-metrics. Dit voorkomt artefacten uit runtime-specifieke histogrammen.",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * sum(rate(container_cpu_usage_seconds_total{container_label_com_docker_compose_service=\"java-checkout\",image!=\"\"}[$__rate_interval]))",
          "legendFormat": "Java"
        },
        {
          "refId": "B",
          "expr": "100 * sum(rate(container_cpu_usage_seconds_total{container_label_com_docker_compose_service=\"node-catalog\",image!=\"\"}[$__rate_interval]))",
          "legendFormat": "Node"
        },
        {
          "refId": "C",
          "expr": "100 * sum(rate(container_cpu_usage_seconds_total{container_label_com_docker_compose_service=\"php-storefront\",image!=\"\"}[$__rate_interval]))",
          "legendFormat": "PHP"
        },
        {
          "refId": "D",
          "expr": "100 * sum(rate(container_cpu_usage_seconds_total{container_label_com_docker_compose_service=\"python-recommendation\",image!=\"\"}[$__rate_interval]))",
          "legendFormat": "Python"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 20 },
              { "color": "red", "value": 60 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Trend - geheugen per runtime",
      "description": "Container working set memory uit cAdvisor, via de OpenTelemetry Collector naar poc-metrics.",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(container_memory_working_set_bytes{container_label_com_docker_compose_service=\"java-checkout\",image!=\"\"}) / 1000000",
          "legendFormat": "Java"
        },
        {
          "refId": "B",
          "expr": "sum(container_memory_working_set_bytes{container_label_com_docker_compose_service=\"node-catalog\",image!=\"\"}) / 1000000",
          "legendFormat": "Node"
        },
        {
          "refId": "C",
          "expr": "sum(container_memory_working_set_bytes{container_label_com_docker_compose_service=\"php-storefront\",image!=\"\"}) / 1000000",
          "legendFormat": "PHP"
        },
        {
          "refId": "D",
          "expr": "sum(container_memory_working_set_bytes{container_label_com_docker_compose_service=\"python-recommendation\",image!=\"\"}) / 1000000",
          "legendFormat": "Python"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 250 },
              { "color": "red", "value": 500 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Afwijking - CPU boven ${baseline_window} baseline",
      "description": "Positieve waarden tonen hoeveel container-CPU boven de rollende baseline uitkomt.",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "clamp_min((100 * sum(rate(container_cpu_usage_seconds_total{container_label_com_docker_compose_service=\"java-checkout\",image!=\"\"}[$__rate_interval]))) - avg_over_time((100 * sum(rate(container_cpu_usage_seconds_total{container_label_com_docker_compose_service=\"java-checkout\",image!=\"\"}[$__rate_interval])))[${baseline_window}:1m]), 0)",
          "legendFormat": "Java above baseline"
        },
        {
          "refId": "B",
          "expr": "clamp_min((100 * sum(rate(container_cpu_usage_seconds_total{container_label_com_docker_compose_service=\"node-catalog\",image!=\"\"}[$__rate_interval]))) - avg_over_time((100 * sum(rate(container_cpu_usage_seconds_total{container_label_com_docker_compose_service=\"node-catalog\",image!=\"\"}[$__rate_interval])))[${baseline_window}:1m]), 0)",
          "legendFormat": "Node above baseline"
        },
        {
          "refId": "C",
          "expr": "clamp_min((100 * sum(rate(container_cpu_usage_seconds_total{container_label_com_docker_compose_service=\"php-storefront\",image!=\"\"}[$__rate_interval]))) - avg_over_time((100 * sum(rate(container_cpu_usage_seconds_total{container_label_com_docker_compose_service=\"php-storefront\",image!=\"\"}[$__rate_interval])))[${baseline_window}:1m]), 0)",
          "legendFormat": "PHP above baseline"
        },
        {
          "refId": "D",
          "expr": "clamp_min((100 * sum(rate(container_cpu_usage_seconds_total{container_label_com_docker_compose_service=\"python-recommendation\",image!=\"\"}[$__rate_interval]))) - avg_over_time((100 * sum(rate(container_cpu_usage_seconds_total{container_label_com_docker_compose_service=\"python-recommendation\",image!=\"\"}[$__rate_interval])))[${baseline_window}:1m]), 0)",
          "legendFormat": "Python above baseline"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 5 },
              { "color": "red", "value": 15 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Afwijking - geheugen boven ${baseline_window} baseline",
      "description": "Positieve waarden tonen hoeveel containergeheugen boven de rollende baseline uitkomt.",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "clamp_min((sum(container_memory_working_set_bytes{container_label_com_docker_compose_service=\"java-checkout\",image!=\"\"}) / 1000000) - avg_over_time((sum(container_memory_working_set_bytes{container_label_com_docker_compose_service=\"java-checkout\",image!=\"\"}) / 1000000)[${baseline_window}:1m]), 0)",
          "legendFormat": "Java above baseline"
        },
        {
          "refId": "B",
          "expr": "clamp_min((sum(container_memory_working_set_bytes{container_label_com_docker_compose_service=\"node-catalog\",image!=\"\"}) / 1000000) - avg_over_time((sum(container_memory_working_set_bytes{container_label_com_docker_compose_service=\"node-catalog\",image!=\"\"}) / 1000000)[${baseline_window}:1m]), 0)",
          "legendFormat": "Node above baseline"
        },
        {
          "refId": "C",
          "expr": "clamp_min((sum(container_memory_working_set_bytes{container_label_com_docker_compose_service=\"php-storefront\",image!=\"\"}) / 1000000) - avg_over_time((sum(container_memory_working_set_bytes{container_label_com_docker_compose_service=\"php-storefront\",image!=\"\"}) / 1000000)[${baseline_window}:1m]), 0)",
          "legendFormat": "PHP above baseline"
        },
        {
          "refId": "D",
          "expr": "clamp_min((sum(container_memory_working_set_bytes{container_label_com_docker_compose_service=\"python-recommendation\",image!=\"\"}) / 1000000) - avg_over_time((sum(container_memory_working_set_bytes{container_label_com_docker_compose_service=\"python-recommendation\",image!=\"\"}) / 1000000)[${baseline_window}:1m]), 0)",
          "legendFormat": "Python above baseline"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 50 },
              { "color": "red", "value": 150 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    }
  ],
  "refresh": "15s",
  "schemaVersion": 42,
  "style": "dark",
  "tags": [
    "customapp",
    "resource-usage",
    "apm",
    "openobserve",
    "trends",
    "anomalies"
  ],
  "templating": {
    "list": [
      {
        "name": "baseline_window",
        "label": "Baseline Window",
        "type": "custom",
        "query": "15m,30m,1h,6h",
        "current": {
          "selected": true,
          "text": "1h",
          "value": "1h"
        },
        "includeAll": false,
        "multi": false,
        "options": [],
        "refresh": 1
      }
    ]
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "title": "CustomApp - Resource Trends & Anomalies",
  "uid": "customapp-resource-trends-anomalies",
  "version": 2,
  "weekStart": ""
}
